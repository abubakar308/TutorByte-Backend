model Availability {
  id        String       @id @default(uuid())
  tutorId   String?
  studentId String?
  dayOfWeek DayOfWeek
  startTime DateTime      
  endTime   DateTime
  isActive  Boolean      @default(true)

  tutor     TutorProfile? @relation(fields: [tutorId], references: [id])

  @@map("availability")
}


