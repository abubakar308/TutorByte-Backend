model Message {
  id         String   @id @default(uuid())
  senderId   String
  receiverId String
  message    String
  isRead     Boolean
  createdAt  DateTime @default(now())
  receiver   User     @relation("receivedMessages", fields: [receiverId], references: [id])
  sender     User     @relation("sentMessages", fields: [senderId], references: [id])

  @@map("messages")
}
